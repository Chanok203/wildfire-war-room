generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mission {
  id         String     @id
  name       String
  droneName  String     @map("drone_name")
  aiStatus   AIStatus   @default(PENDING) @map("ai_status")
  pushStatus PushStatus @default(IDLE) @map("push_status")
  latitude   Float
  longitude  Float
  inputData  Json?      @map("input_data")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  hotspots   Hotspot[]

  @@map("missions")
}

model Hotspot {
  id         String      @id @default(uuid())
  missionId  String      @map("mission_id")
  type       HotspotType
  latitude   Float
  longitude  Float
  confidence Float?
  geometry   Json
  createdAt  DateTime    @default(now()) @map("created_at")
  mission    Mission     @relation(fields: [missionId], references: [id])

  @@index([missionId])
  @@index([type])
  @@map("hotspots")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(uuid())
  apiKey    String   @unique
  createdAt DateTime @default(now())
}

enum AIStatus {
  PENDING
  CAPTURING
  WAITING_AI
  AI_PROCESSING
  COMPLETED
  FAILED
}

enum PushStatus {
  IDLE
  PENDING
  PUSHING
  PUSHED
  FAILED
}

enum HotspotType {
  PRED_30
  PRED_45
  PRED_60
}
